{
  "name": "app-dist",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
  "dev": "vite",
  "dev:electron": "vite --config vite.config.electron.ts",
  "build": "tsc && vite build",
  "build:electron": "tsc && vite build --config vite.config.electron.ts && electron-builder",
  "preview": "vite preview"
},
  "dependencies": {
    "axios": "^1.7.9",
    "date-fns": "^4.4.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.3",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.3",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "build": {
    "appId": "com.distridentales.app",
    "productName": "DistriDentales",
    "copyright": "Copyright © 2024 DistriDentales de la Costa",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "forceCodeSigning": false,
      "icon": "public/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico",
      "installerHeaderIcon": "public/logo.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DistriDentales"
    }
  }
}
